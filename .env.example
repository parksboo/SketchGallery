# SketchGallery unified environment file
# Fill all REPLACE_ME values before deployment.

# ---------- GCP / Cluster ----------
PROJECT_ID=sketchgallery
REGION=us-central1
ZONE=us-central1-a
NAMESPACE=default

# ---------- Storage ----------
GCS_BUCKET=REPLACE_ME_GCS_BUCKET

# ---------- Webserver -> Ray dispatch ----------
# Ray generation endpoint reachable from webserver pods.
RAY_GENERATION_URL=http://sketchgallery-ray:8000/generate
# Shared token used in both webserver and raycluster auth/callback.
RAY_SHARED_TOKEN=REPLACE_ME_STRONG_TOKEN
# Public URL of webserver ingress/load balancer (used for Ray callback URL generation)
WEB_PUBLIC_BASE_URL=https://REPLACE_ME_WEB_DOMAIN

# ---------- Ray runtime ----------
# If ray service is running inside the same cluster and connected to Ray head, use your in-cluster Ray address.
# Example: ray://ray-head.ray.svc.cluster.local:10001
RAY_ADDRESS=REPLACE_ME_RAY_ADDRESS
RAY_NAMESPACE=sketchgallery
RAY_GET_TIMEOUT_SEC=300
CALLBACK_TIMEOUT_SEC=5

# ---------- Webserver / Postgres ----------
HOST=0.0.0.0
PORT=5050
PGHOST=postgres
PGPORT=5432
PGDATABASE=sketchgallery
PGUSER=sketchgallery
PGPASSWORD=REPLACE_ME_POSTGRES_PASSWORD

# ---------- GCP Credentials (local only) ----------
# For local runs. In GKE production, prefer Workload Identity.
# If the path contains spaces, wrap it with quotes.
# GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/with spaces/key.json"
